# QuantTrade development environment example.
# Copy to .env for local development. Do not commit real secrets.

QT_ENV=development
QT_OPERATOR=local_operator

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quanttrade
POSTGRES_USER=quanttrade
POSTGRES_PASSWORD=quanttrade_dev_password

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_ENDPOINT=http://localhost:9001
MINIO_ROOT_USER=quanttrade_minio
MINIO_ROOT_PASSWORD=quanttrade_minio_dev_password
MINIO_BUCKET_DATA_SNAPSHOTS=quanttrade-data-snapshots
MINIO_BUCKET_LEAN_ARTIFACTS=quanttrade-lean-artifacts

HTTP_PROXY=http://127.0.0.1:18081
HTTPS_PROXY=http://127.0.0.1:18081
