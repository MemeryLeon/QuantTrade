  "info": {
    "title": "QuantTrade API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/backtests/mock": {
      "post": {
        "operationId": "submit_mock_backtest_backtests_mock_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MockBacktestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BacktestSubmissionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit Mock Backtest",
        "tags": [
          "backtests"
        ]
      }
    },
