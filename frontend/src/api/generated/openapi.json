        "type": "object"
      },
      "QualityFlag": {
        "enum": [
          "MISSING_BARS",
          "DUPLICATE_BARS",
          "OUT_OF_ORDER",
          "STALE_CACHE",
          "PROVIDER_DEGRADED",
          "PROVIDER_UNAVAILABLE",
          "ADJUSTMENT_FACTOR_MISSING",
          "CALENDAR_MISMATCH",
