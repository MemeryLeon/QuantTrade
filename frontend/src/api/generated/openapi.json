      "MockBacktestRequest": {
        "properties": {
          "adjustment": {
            "enum": [
              "qfq",
              "hfq",
              "none"
            ],
            "title": "Adjustment",
            "type": "string"
          },
          "base_currency": {
            "const": "CNY",
            "title": "Base Currency",
            "type": "string"
          },
          "benchmark": {
            "minLength": 1,
            "title": "Benchmark",
            "type": "string"
          },
          "commission_model": {
            "const": "mock",
            "title": "Commission Model",
            "type": "string"
          },
          "data_snapshot_id": {
            "minLength": 1,
            "title": "Data Snapshot Id",
            "type": "string"
          },
          "end_date": {
            "format": "date",
            "title": "End Date",
            "type": "string"
          },
          "initial_capital": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ],
            "title": "Initial Capital"
          },
          "instruments": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Instruments",
            "type": "array"
          },
          "parameters": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/BacktestParameterInput"
            },
            "title": "Parameters",
            "type": "array"
          },
          "resolution": {
            "const": "daily",
            "title": "Resolution",
            "type": "string"
          },
          "slippage_model": {
            "const": "mock",
            "title": "Slippage Model",
            "type": "string"
          },
          "start_date": {
            "format": "date",
