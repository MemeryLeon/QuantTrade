        "type": "string"
      },
      "TradingCalendarResponse": {
        "properties": {
          "market": {
            "title": "Market",
            "type": "string"
          },
          "timezone": {
            "title": "Timezone",
            "type": "string"
          },
          "trading_days": {
            "items": {
              "format": "date",
              "type": "string"
            },
            "title": "Trading Days",
            "type": "array"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "market",
          "version",
          "timezone",
          "trading_days"
        ],
