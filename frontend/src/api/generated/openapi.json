            "type": "string"
          },
          "instrument_id": {
            "title": "Instrument Id",
            "type": "string"
          },
          "is_delayed": {
            "title": "Is Delayed",
            "type": "boolean"
          },
          "market": {
            "const": "CN_A",
            "title": "Market",
            "type": "string"
          },
          "provider": {
            "const": "akshare",
            "title": "Provider",
            "type": "string"
          },
          "quality_flags": {
            "items": {
              "$ref": "#/components/schemas/QualityFlag"
            },
            "title": "Quality Flags",
            "type": "array"
          },
          "resolution": {
            "const": "daily",
            "title": "Resolution",
            "type": "string"
          },
          "stale_age_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
